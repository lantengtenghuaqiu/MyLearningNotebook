#version 410 core
layout (location = 0) in vec3 _vertex;

layout (std140) uniform Transform
{
    mat4 _P;
    mat4 _c;
    mat4 _r;
    mat4 _t;
};

out vec3 TexCoords;

void main()
{
    TexCoords = _vertex;
    mat4 V = _r * _c;
    vec4 vertex = _P * V * vec4(_vertex, 1.0);
    gl_Position = vertex;
} 