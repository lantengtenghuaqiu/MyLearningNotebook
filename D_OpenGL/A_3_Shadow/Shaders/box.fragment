#version 410 core
out vec4 fragment_color;

in vec3 _sunlight_dir;
in vec3 _normal;
in vec2 _uv;

float LinearZDepth(float depth){
    float zColor = depth * 2.0 - 1.0;
    return  (2.0 * 0.01 * 30.0) / (30.0 + 0.01 - zColor * (30.0 - 0.01));
}


void main()
{

    float ndl = dot(_sunlight_dir,_normal);

    vec3 finalColor = ndl * vec3(1.0,1.0,1.0);

    //fragment_color = vec4(1.0,1.0,1.0,1.0);
    fragment_color = vec4(finalColor,1.0);


}