#version 460 core
layout (location = 0) in vec3 triangle;
layout (location = 1) in vec3 vertexcolor1;
layout (location = 2) in vec2 uv;

out vec3 our_color;
out vec2 coordinates;

void main()
{
    gl_Position = vec4(triangle.x , triangle.y , triangle.z ,1.0f);
    our_color = vertexcolor1;
    coordinates = uv;
}