#version 410 core
out vec4 fragment_color;

in vec2 _uv;

uniform sampler2D _maizhimeng;


void main(){
    vec4 logoTexCol = texture(_maizhimeng , _uv);


    vec4 finalColor = logoTexCol;

    //fragment_color = vec4(1.0,0.0,0.0,1.0);
    //fragment_color = vec4(_uv,0.0,1.0);
    fragment_color = finalColor;
}